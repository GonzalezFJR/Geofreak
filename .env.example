# ─── App ──────────────────────────────────────────────
APP_NAME=GeoFreak
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ─── Security ─────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Admin panel ──────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=change-me

# ─── AWS credentials ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# ─── DynamoDB ─────────────────────────────────────────
DYNAMODB_TABLE_PREFIX=geofreak_
# For local development with DynamoDB Local (leave empty for real AWS)
DYNAMODB_ENDPOINT_URL=

# ─── S3 ───────────────────────────────────────────────
S3_BUCKET_NAME=geofreak-assets
# For local development with LocalStack (leave empty for real AWS)
S3_ENDPOINT_URL=

# ─── Analytics ────────────────────────────────────────
# Flush events to S3 every N events (and persist counters)
ANALYTICS_FLUSH_SIZE=50

# ─── Docker ───────────────────────────────────────────
DOCKER_CONTAINER_NAME=geofreak-app
DOCKER_IMAGE_NAME=geofreak

# ─── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="
MAIL_TO=

# ─── Captcha (Cloudflare Turnstile) ─────────────
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=